{
  "id": "7e5c5afe-ae23-45ad-8668-6be49b98533d",
  "type": "authentication-assurance",
  "external_service": "mocky",
  "external_application_id_param": "application_id",
  "processes": {
    "apply": {
      "request": {
        "schema": {}
      },
      "pre_hook": {
        "verifications": [

        ],
        "additional_parameters": [
          {
            "type": "http_request",
            "details": {
              "url": "http://host.docker.internal:4000/apply",
              "method": "POST",
              "static_headers": {
                "Content-Type": "application/json",
                "Authorization": "Bearer dummy-token"
              },
              "body_mapping_rules": [
                { "from": "$.request_body", "to": "*" }
              ]
            }
          }
        ]
      },
      "execution": {
        "type": "http_request",
        "http_request": {
          "url": "http://host.docker.internal:4000/apply",
          "method": "POST",
          "header_mapping_rules": [
            { "static_value": "application/json", "to": "Content-Type" },
            { "static_value": "Bearer dummy-token", "to": "Authorization" }
          ],
          "body_mapping_rules": [
            { "from": "$.request_body", "to": "*" },
            { "from": "$.user.sub", "to": "user_id" },
            { "from": "$.user.email", "to": "mail_address" },
            { "from": "$.user.custom_properties.token", "to": "token" }
          ]
        }
      },
      "store": {
        "application_details_mapping_rules": [
          { "from": "$.request_body", "to": "*" },
          { "from": "$.response_body", "to": "*" }
        ]
      },
      "response": {
        "body_mapping_rules": [
          { "from": "$.response_body", "to": "*" }
        ]
      }
    },
    "request-authentication": {
      "request": {
        "schema": {}
      },
      "execution": {
        "type": "http_request",
        "http_request": {
          "url": "http://host.docker.internal:4000/request-authentication",
          "method": "POST",
          "header_mapping_rules": [
            { "static_value": "application/json", "to": "Content-Type" },
            { "static_value": "Bearer dummy-token", "to": "Authorization" }
          ],
          "body_mapping_rules": [
            { "from": "$.request_body", "to": "*"}
          ],
          "static_body": {}
        }
      },
      "store": {
        "application_details_mapping_rules": [
          { "from": "$.request_body", "to": "*" },
          { "from": "$.response_body", "to": "*" }
        ]
      },
      "response": {
        "body_mapping_rules": [
          { "from": "$.response_body", "to": "*" }
        ]
      }
    },
    "authentication-status": {
      "request": {
        "schema": {
          "type": "object",
          "required": [],
          "properties": {}
        }
      },
      "execution": {
        "type": "http_request",
        "http_request": {
          "url": "http://host.docker.internal:4000/authentication-status",
          "method": "POST",
          "header_mapping_rules": [
            { "static_value": "application/json", "to": "Content-Type" },
            { "static_value": "Bearer dummy-token", "to": "Authorization" }
          ],
          "dynamic_body_keys": [],
          "static_body": {}
        }
      },
      "store": {
        "application_details_mapping_rules": [
          { "from": "$.request_body", "to": "*" },
          { "from": "$.response_body", "to": "*" }
        ]
      },
      "response": {
        "body_mapping_rules": [
          { "from": "$.response_body", "to": "*" }
        ]
      }
    },
    "evaluate-result": {
      "execution": {
        "type": "no_action"
      },
      "transition": {
        "approved": {
          "any_of": [
            [
              {
                "path": "$.request_body.approved",
                "type": "boolean",
                "operation": "eq",
                "value": true
              },
              {
                "path": "$.request_body.rejected",
                "type": "boolean",
                "operation": "eq",
                "value": false
              },
              {
                "path": "$.application.processes.request-authentication.success_count",
                "type": "integer",
                "operation": "gte",
                "value": 1
              },
              {
                "path": "$.application.processes.authentication-status.success_count",
                "type": "boolean",
                "operation": "gte",
                "value": 1
              }
            ]
          ]
        },
        "rejected": {
          "any_of": [
            [
              {
                "path": "$.request_body.approved",
                "type": "boolean",
                "operation": "eq",
                "value": false
              },
              {
                "path": "$.request_body.rejected",
                "type": "boolean",
                "operation": "eq",
                "value": true
              }
            ]
          ]
        }
      }
    }
  }
}