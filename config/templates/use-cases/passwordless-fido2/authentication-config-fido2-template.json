{
  "type": "fido2",
  "metadata": {},
  "interactions": {
    "fido2-registration-challenge": {
      "execution": {
        "function": "webauthn4j_registration_challenge",
        "details": {
          "rp_id": "${FIDO2_RP_ID}",
          "allowed_origins": ["${FIDO2_ALLOWED_ORIGIN}"],
          "rp_name": "${FIDO2_RP_NAME}",
          "token_binding_id": null,
          "require_resident_key": true,
          "attestation_preference": "direct",
          "user_presence_required": true,
          "authenticator_attachment": "platform",
          "user_verification_required": true
        }
      },
      "response": {
        "body_mapping_rules": [{ "from": "$.execution_webauthn4j", "to": "*" }]
      }
    },
    "fido2-registration": {
