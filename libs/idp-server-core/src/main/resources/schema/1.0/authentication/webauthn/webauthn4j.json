{
  "type": "object",
  "required": ["type", "details"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["webauthn4j"]
    },
    "details": {
      "type": "object",
      "required": ["webauthn4j"],
      "properties": {
        "webauthn4j": {
          "type": "object",
          "required": [
            "rp_id",
            "origin",
            "rp_name",
            "require_resident_key",
            "attestation_preference",
            "user_presence_required",
            "authenticator_attachment",
            "user_verification_required"
          ],
          "properties": {
            "rp_id": {
              "type": "string"
            },
            "origin": {
              "type": "string",
              "format": "uri"
            },
            "rp_name": {
              "type": "string"
            },
            "token_binding_id": {
              "type": ["string", "null"]
            },
            "require_resident_key": {
              "type": "boolean"
            },
            "attestation_preference": {
              "type": "string",
              "enum": ["none", "indirect", "direct"]
            },
            "user_presence_required": {
              "type": "boolean"
            },
            "authenticator_attachment": {
              "type": "string",
              "enum": ["cross-platform", "platform"]
            },
            "user_verification_required": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
